<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="GtkPopoverMenu" id="popup_menu">
    <property name="can_focus">False</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="homogeneous">True</property>
        <property name="visible">True</property>
        <property name="spacing">10</property>
        <property name="margin">6</property>
        <child>
          <object class="GtkModelButton" id="menu_btn_about">
            <property name="visible">True</property>
            <property name="text" translatable="yes">About</property>
          </object>
        </child>
        <child>
          <object class="GtkModelButton" id="menu_btn_eqlz">
            <property name="visible">True</property>
            <property name="text" translatable="yes">Equalizer</property>
          </object>
        </child>
        <child>
          <object class="GtkModelButton" id="menu_btn_quit">
            <property name="visible">True</property>
            <property name="text" translatable="yes">Quit</property>
          </object>
        </child>
      </object>
    </child>
  </object>

  <object class="GtkApplicationWindow" id="win_main">
    <property name="default-width">600</property>
    <property name="default-height">300</property>
    <child type="titlebar">
      <object class="GtkHeaderBar" id="hd_bar">
        <property name="visible">True</property>
        <property name="show-close-button">False</property>
        <property name="title"></property>
        <property name="subtitle"></property>
        <child>
          <object class="GtkBox" id="ctrl_box_hd">
            <property name="visible">True</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkButton" id="ctrl_btn_prev">
                <property name="visible">True</property>
                <property name="sensitive">False</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <property name="has_tooltip">True</property>
                <property name="tooltip_text" translatable="yes">Play the previous track</property>
                <property name="image">mp-prev</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="ctrl_btn_stop">
                <property name="visible">True</property>
                <property name="sensitive">False</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <property name="has_tooltip">True</property>
                <property name="tooltip_text" translatable="yes">Stop the current track</property>
                <property name="image">mp-stop</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="ctrl_btn_play">
                <property name="visible">True</property>
                <property name="sensitive">False</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <property name="has_tooltip">True</property>
                <property name="tooltip_text" translatable="yes">Play the first track of the playlist</property>
                <property name="image">mp-play</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="ctrl_btn_next">
                <property name="visible">True</property>
                <property name="sensitive">False</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <property name="has_tooltip">True</property>
                <property name="tooltip_text" translatable="yes">Play the next track</property>
                <property name="image">mp-next</property>
              </object>
            </child>
          </object>
          <packing>
            <property name="pack_type">start</property>
          </packing>
        </child>
        <child>
          <object class="GtkBox" id="act1_box_hd">
            <property name="visible">True</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkMenuButton" id="act1_pop_menu">
                <property name="visible">True</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <property name="popover">popup_menu</property>
                <property name="label">Ξ</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="act1_btn_close">
                <property name="visible">True</property>
                <property name="sensitive">True</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <property name="label">⊗</property>
              </object>
            </child>
          </object>
          <packing>
            <property name="pack_type">end</property>
          </packing>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkPaned" id="bd_pan1">
        <property name="visible">True</property>
        <child>
          <object class="GtkNotebook" id="playlist_tabs">
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="show_tabs">True</property>
            <property name="show_border">True</property>
            <child>
              <placeholder />
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="explorer_box">
            <property name="visible">True</property>
            <property name="orientation">vertical</property>
            <property name="border_width">2</property>
            <child>
              <placeholder />
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>

    </child>
  </object>
  <object class="GtkImage" id="mp-prev"> <property name="pixel_size">20</property><property name="icon_name">gtk-media-previous</property></object>
  <object class="GtkImage" id="mp-next"> <property name="pixel_size">20</property><property name="icon_name">gtk-media-next</property></object>
  <object class="GtkImage" id="mp-play"> <property name="pixel_size">20</property><property name="icon_name">gtk-media-play</property></object>
  <object class="GtkImage" id="mp-stop"> <property name="pixel_size">20</property><property name="icon_name">gtk-media-stop</property></object>
  <object class="GtkImage" id="mp-pause"><property name="pixel_size">20</property><property name="icon_name">gtk-media-pause</property></object>
</interface>
